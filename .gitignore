# Local-only generated/runtime material.
local/
artifacts/
analysis/
data_external/
# Plural `references/` is tracked lightweight notes/registries; do not ignore it.
# Use `.external_repos/` or `.reference_cache/` for local source inspection.
# `reference/` remains ignored as a legacy local-only clone/cache path.
reference/
reference_downloads/
benchmark_downloads/
.external_repos/
.reference_cache/

# Python/build/editor caches.
.pycache_compile/
.pytest_cache/
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.env
.DS_Store

# Training/model artifacts.
adapters/
models/
checkpoints/
wandb/
runs/
*.safetensors
*.ckpt
*.pt
*.pth

# External/binary downloads.
*.pdf
*.parquet
*.arrow
*.db
*.sqlite
*.zip
*.tar
*.tar.gz
*.jsonl.gz

# JSONL is ignored by default; only active fixtures, releases, and test data
# are allowlisted below. Do not broadly unignore `data/retrace_bench/**` because
# that directory is also used for local generated diagnostics/blueprints.
*.jsonl
!tests/**/*.jsonl
!data/fixtures/**/*.jsonl
!examples/**/*.jsonl
!data/retrace_learn/v1/boundary_audit/**
!data/retrace_bench/sample_20_v2/**
!data/retrace_bench/sample_80_hard_en/**
!data/retrace_bench/test_800_en/**
!data/retrace_bench/test_800_templateheldout_en/**
!data/retrace_bench/test_800_templateheldout_v2_en/**
!data/retrace_supervision/train_3000_en/**
!data/retrace_supervision/dev_400_en/**
!release/huggingface/ReTrace-Bench/**
!outputs/**
outputs/**/.DS_Store
