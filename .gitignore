# Local experiment outputs.
/results/
/runs/
/scratch/
/data/
/datasets/
/external_references/
/artifacts/
/local/

# Python/build/editor caches.
.pytest_cache/
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
uv.lock
.env
.DS_Store

# Secrets and credentials.
.tokens
.tokens/
.env.*
*.env
.envrc
secrets.*
secret.*
*.secret
tokens.*
*.pem
*.key
*_token
*_token.txt
*.token
hf_token*
.hf_token
*_api_key*
*.apikey

# Model, checkpoint, database, and dataset artifacts.
*.safetensors
*.gguf
*.bin
*.ckpt
*.pt
*.pth
*.parquet
*.arrow
*.db
*.sqlite
*.jsonl.gz

# JSONL is ignored by default; smoke fixtures are allowlisted.
*.jsonl
!mempatch/tests/**/*.jsonl

# Archives and scratch PDFs are ignored by default.
*.pdf
*.zip
*.tar
*.tar.gz

# LaTeX build intermediates.
*.aux
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
