# Local external-reference clones are intentionally kept out of project history.
# Use tracked `references/` only for lightweight YAML registries and Markdown
# notes. Use ignored `reference/` only for local cloned repos / downloaded papers.
reference/

# Runtime and generated outputs.
outputs/
artifacts/
analysis/
# Exclude output datasets except fixtures and tests
*.jsonl
!tests/**/*.jsonl
!data/fixtures/**/*.jsonl
# Committed calibration fixtures (small, hand/template generated, not full datasets).
!data/retrace_bench/sample_80_hard_en/
!data/retrace_bench/sample_80_hard_en/*.jsonl
!data/retrace_bench/sample_80_hard_en/*.json
!data/retrace_bench/sample_80_hard_en/README.md
# v2 toy smoke sample (4 scenarios) referenced by manifest.json and the v2 smoke test.
!data/retrace_bench/sample_20_v2/
!data/retrace_bench/sample_20_v2/*.jsonl
!data/retrace_bench/sample_20_v2/*.json
!data/retrace_bench/sample_20_v2/README.md
