# Local-only generated/runtime material.
local/
artifacts/
analysis/
data_external/
# Plural `references/` is tracked lightweight notes/registries; do not ignore it.
# Use `.external_repos/` or `.reference_cache/` for local source inspection.
# `reference/` remains ignored as a legacy local-only clone/cache path.
reference/
reference_downloads/
benchmark_downloads/
.external_repos/
.reference_cache/

# Python/build/editor caches.
.pycache_compile/
.pytest_cache/
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.env
.DS_Store

# Training/model artifacts.
adapters/
models/
checkpoints/
wandb/
runs/
*.safetensors
*.ckpt
*.pt
*.pth

# External/binary downloads.
*.pdf
*.parquet
*.arrow
*.db
*.sqlite
*.zip
*.tar
*.tar.gz
*.jsonl.gz

# JSONL is ignored by default; only active fixtures, releases, and test data
# are allowlisted below. Do not broadly unignore `data/retrace_bench/**` because
# that directory is also used for local generated diagnostics/blueprints.
*.jsonl
!tests/**/*.jsonl
!data/fixtures/**/*.jsonl
!examples/**/*.jsonl
!data/retrace_learn/v1/boundary_audit/**
# Canonical ReTrace-Bench (internal "v1.1") public paper-facing splits.
# main/hard/realistic/calibration are committed; private_hidden is NOT (private
# evaluation split — distributed only via the private HF bundle, never on GitHub).
!data/retrace_bench_v1_1/main_3000_en/**
!data/retrace_bench_v1_1/hard_500_en/**
!data/retrace_bench_v1_1/realistic_200_en/**
!data/retrace_bench_v1_1/calibration_80_en/**
# private_hidden is a PRIVATE evaluation split: do NOT commit ANY of it to
# GitHub (not the scenarios, manifest, or README). It is distributed only via a
# private HF bundle / locally after generation.
data/retrace_bench_v1_1/private_hidden_200_en/
# Legacy v1.0 / development split package (manifests + already-tracked splits).
!data_legacy/retrace_bench_v1_0/**
!data_legacy/retrace_bench_dev_artifacts/**
# HF release bundle: ship manifests/checksums/cards; keep full JSONL local-only.
!release/huggingface/ReTrace-Bench/**
!hf_release/retrace_bench_v1_1/**/manifest.json
!hf_release/retrace_bench_v1_1/**/checksums.json
# Annotation packets (public, gold-free demo packets only — see below).
!annotation_packets/retrace_bench_v1_1/**

# outputs/ is intentionally TRACKED (benchmark prediction dumps + metrics are
# committed for reproducibility/sharing). This allowlist overrides the global
# *.jsonl ignore above so prediction JSONL under outputs/ is committed too.
# Only machine-local noise inside outputs/ stays ignored.
!outputs/**
outputs/**/.DS_Store
# Local ReTrace-Learn / method scratch outputs that land at the outputs/ root.
# These are NOT part of the ReTrace-Bench release (benchmark dumps live under
# outputs/retrace_bench/). Ignore only the root-level files, not the subtree.
/outputs/fc_*.jsonl
/outputs/fc_*.json
/outputs/multiagent_*.jsonl
/outputs/multiagent_*.json
/outputs/stale_cupmem_*.json
# Official ReTrace-Bench v1.0 model-suite outputs are intentionally trackable.
!outputs/retrace_bench/v1_0/**
# v1.1 offline-baseline per-scenario PREDICTION dumps are large (~43MB) and
# deterministically regenerable via scripts/run_retrace_bench_baseline.py. Keep
# the small *.metrics.json results committed, but not the bulky prediction JSONL.
outputs/retrace_bench_v1_1/baselines/*.jsonl
