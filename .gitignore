local/*
artifacts/
analysis/
data_external/
# Plural `references/` is tracked lightweight notes/registries; do not ignore it.
# Use `.external_repos/` or `.reference_cache/` for local source inspection.
# `reference/` remains ignored as a legacy local-only clone/cache path.
reference/
reference_downloads/
benchmark_downloads/
.external_repos/
.reference_cache/

# Python/build/editor caches.
.pycache_compile/
.pytest_cache/
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.env
.DS_Store

# Training/model artifacts.
adapters/
models/
checkpoints/
wandb/
runs/
*.safetensors
*.gguf
*.bin
*.ckpt
*.pt
*.pth

# External/binary downloads.
*.pdf
*.parquet
*.arrow
*.db
*.sqlite
*.zip
*.tar
*.tar.gz
*.jsonl.gz

# JSONL is ignored by default; only active fixtures and release bundles
# are allowlisted below.
*.jsonl
!tests/**/*.jsonl
!hf_release/mempatch/**/scenarios.jsonl
!hf_release/mempatch/**/manifest.json
!hf_release/mempatch/**/checksums.json
!hf_release/mempatch/**/README.md
!hf_release/mempatch/**/dataset_info.json
!hf_release/mempatch/VERSION
outputs/

# Secrets / credentials / tokens — never commit any of these.
.env.*
*.env
.envrc
secrets.*
*.pem
*_token
*_token.txt
*.token
hf_token*
.hf_token
*_api_key*
*.apikey

# Local Hugging Face / model-hub caches.
.huggingface/
.cache/huggingface/
huggingface/
hf_home/

# Explicitly allow tracking local evaluation results
!local/results/
!local/results/**

