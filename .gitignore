# Local-only generated/runtime material.
local/
artifacts/
analysis/
data_external/
# Plural `references/` is tracked lightweight notes/registries; do not ignore it.
# Use `.external_repos/` or `.reference_cache/` for local source inspection.
# `reference/` remains ignored as a legacy local-only clone/cache path.
reference/
reference_downloads/
benchmark_downloads/
.external_repos/
.reference_cache/

# Python/build/editor caches.
.pycache_compile/
.pytest_cache/
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.env
.DS_Store

# Training/model artifacts.
adapters/
models/
checkpoints/
wandb/
runs/
*.safetensors
*.gguf
*.bin
*.ckpt
*.pt
*.pth

# External/binary downloads.
*.pdf
*.parquet
*.arrow
*.db
*.sqlite
*.zip
*.tar
*.tar.gz
*.jsonl.gz

# JSONL is ignored by default; only active fixtures, releases, and test data
# are allowlisted below. Do not broadly unignore `data/mempatch/**` because
# that directory is also used for local generated diagnostics/blueprints.
*.jsonl
!tests/**/*.jsonl
!data/retrace_learn/v1/boundary_audit/**
# HF release bundle: ship manifests/checksums/cards; keep full JSONL local-only.
!hf_release/mempatch_v1_1/**/manifest.json
!hf_release/mempatch_v1_1/**/checksums.json
outputs/

# Secrets / credentials / tokens — never commit any of these.
.env.*
*.env
.envrc
secrets.*
*.pem
*_token
*_token.txt
*.token
hf_token*
.hf_token
*_api_key*
*.apikey

# Local Hugging Face / model-hub caches.
.huggingface/
.cache/huggingface/
huggingface/
hf_home/
