# Copy this file to .env and fill in local secrets.
# Never commit .env or real API keys.

# SiliconFlow API key for live development runs.
SILICONFLOW_API_KEY=

# Default live-pilot provider and model.
RETRACE_LIVE_PROVIDER=siliconflow
RETRACE_LIVE_MODEL=

# Optional explicit safety caps for exploratory live runs.
RETRACE_LIVE_MAX_CALLS=24
RETRACE_LIVE_MAX_TOKENS=60000
