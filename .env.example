# Copy this file to .env and fill in local secrets.
# Never commit .env or real API keys.

# Google Gemini API key for live development runs.
GEMINI_API_KEY=

# Default live provider and model.
RETRACE_LIVE_PROVIDER=gemini
RETRACE_LIVE_MODEL=gemini-3.5-flash

# Safety caps for development-scale exploratory runs.
RETRACE_LIVE_MAX_CALLS=1000
RETRACE_LIVE_MAX_TOKENS=2000000
