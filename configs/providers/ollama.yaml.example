# Ollama native chat API (/api/chat) on a local server. Local auth is typically none.
# Copy to configs/providers/ollama.yaml and edit, then:
#   --provider-config configs/providers/ollama.yaml
name: ollama
mode: ollama-chat
base_url: http://localhost:11434/api/chat
api_key_env: null                    # no auth for a local Ollama server
model: llama3.1
timeout: 120
max_retries: 1
temperature: 0.0
max_tokens: 1024
stream: false
