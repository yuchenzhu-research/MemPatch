# LM Studio local server (OpenAI-compatible). Copy to configs/providers/lmstudio.yaml, then:
#   --provider-config configs/providers/lmstudio.yaml
name: lmstudio
mode: custom-openai-compatible
base_url: http://localhost:1234/v1/chat/completions
api_key_env: LMSTUDIO_API_KEY        # LM Studio ignores the key; set any non-empty value
model: local-model
timeout: 120
max_retries: 1
temperature: 0.0
max_tokens: 1024
stream: false
