# Anthropic Messages API (/v1/messages, Claude message schema).
# Copy to configs/providers/anthropic.yaml and edit, then:
#   --provider-config configs/providers/anthropic.yaml
name: anthropic
mode: anthropic-messages
base_url: https://api.anthropic.com/v1/messages
api_key_env: ANTHROPIC_API_KEY       # sent as the x-api-key header
model: claude-3-5-sonnet-latest
timeout: 60
max_retries: 2
temperature: 0.0
max_tokens: 1024
stream: false
extra_headers:
  anthropic-version: "2023-06-01"
